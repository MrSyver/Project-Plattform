# Beispiel-Konfiguration (12-Factor). Kopieren nach `.env`, Werte setzen.
# Secrets in Prod NICHT hier, sondern im Key Vault / HashiCorp Vault (§ 9.3).

# --- App-Datenbank (MSSQL) ---
DB_PASSWORD=ChangeMe_Str0ng!

# --- Auth ---
# entra | local | hybrid
Auth__Mode=local

# --- Editoren (Bearbeitungsmodus, ADR-018) ---
# Komma-getrennte E-Mail-Allowlist wird über appsettings/Umgebung als Array gesetzt,
# z. B. Editors__Allowlist__0=max@kunde.de  Editors__Allowlist__1=admin@kunde.de
Editing__PublishWorkflow=draft-publish

# --- Power BI ---
Bi__Provider=PowerBiService

# --- Netzwerk (optionaler App-seitiger Riegel, § 9.1) ---
Network__AllowedCidrs=

# --- Dateiablage (On-Prem) ---
Storage__LocalPath=/data/files
